# Monorepo ALEPH — nivel raíz. El .gitignore de la app vive en app_streamlit/.gitignore.
__pycache__/
*.pyc
.venv/
venv/
node_modules/
.next/
dist/
build/
.env
.env.local
.DS_Store
.ruff_cache/
.pytest_cache/
*.egg-info/
# Archivos intermedios (regenerables) — nunca se commitean (ver metodología en CLAUDE.md)
.tmp/
.tmp*
*.tmp
# Basura suelta en la RAÍZ (capturas, logs). Las imágenes de producto viven en web/public/ o
# app_streamlit/assets/, no en la raíz, así que ignorar PNG/LOG sueltos en raíz es seguro.
/*.png
/*.log
