# ============================================================================
# ALEPH /web — variables de entorno (plantilla)
# ============================================================================
# Copia este archivo a .env.local para desarrollo, o cárgalo en Vercel
# (Project Settings -> Environment Variables) para producción.
#
# NUNCA pongas valores reales/secretos en este archivo (está versionado).
# Los secretos van en .env.local (gitignored) o en Vercel.
#
# AUTH CONFIG-DRIVEN: si NO defines AUTH_MICROSOFT_ENTRA_ID_ID, la auth queda
# APAGADA (modo dev local: el /web habla con el API local que también tiene la
# auth apagada, sin login). Definir las variables de Entra ENCIENDE el login.
# ----------------------------------------------------------------------------

# --- API de ALEPH (FastAPI en Azure) ----------------------------------------
# Base URL del API. Dev local: http://localhost:8000  ·  Prod: el App Service.
ALEPH_API_URL=https://cg-aleph-api.azurewebsites.net

# Scope del API expuesto en Entra (App registration del API -> Expose an API).
# Formato: api://<APPLICATION_ID_DEL_API>/access_as_user
# Pedirlo en el login hace que el access_token salga con la AUDIENCIA del API,
# que es lo que el API valida. Sin esto el token no sirve para /v1.
ALEPH_API_SCOPE=api://<API_APP_ID>/access_as_user

# --- Auth.js v5 / NextAuth ---------------------------------------------------
# Secreto para firmar/cifrar la cookie de sesión. Genéralo con:
#   npx auth secret      (lo escribe en .env.local)   ó   openssl rand -base64 33
AUTH_SECRET=

# App registration del WEB (NO la del API). Application (client) ID + secret.
AUTH_MICROSOFT_ENTRA_ID_ID=<WEB_APP_CLIENT_ID>
AUTH_MICROSOFT_ENTRA_ID_SECRET=<WEB_APP_CLIENT_SECRET>

# Issuer del tenant (mismo tenant del API). SIN barra final.
# https://login.microsoftonline.com/<TENANT_ID>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0

# URL canónica de producción (recomendado fijarla en prod para que el
# redirect a Entra siempre apunte al dominio correcto). En Vercel, si se omite,
# Auth.js confía en el host automáticamente (AUTH_TRUST_HOST). Dev: omitir.
# AUTH_URL=https://<tu-dominio-en-vercel>
