# .env.example — plantilla de variables de entorno de ALEPH (api/conectores).
# COPIA este archivo a `.env` (gitignored) y rellena los valores REALES. JAMÁS commitees `.env`.
# En producción usa el almacén de secretos (Azure Key Vault / GitHub Secrets / app settings),
# nunca un archivo en el repo.

# --- Conector SINCO (DATAMART SQL Server) — actuals de obra / valor ganado (Fase 1) ---------------
# View de solo lectura: ADP_DTM_VFACT.ControlProyecto. Solo se usan en vivo (Paso 2); los tests
# corren con fixture y NO necesitan estas variables.
SINCO_SERVER=datamart.sincoerp.com,4263   # host,puerto (estilo SQL Server)
SINCO_DB=SincoCGDW
SINCO_USER=                                # usuario read-only de SINCO (lo provee SINCOSOFT)
SINCO_PASSWORD=                            # secreto — nunca en git

# --- Supabase (datos de proyectos) — solo si se lee/escribe contra la BD ---------------------------
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_KEY=                            # secret API key (sb_secret_...); jamás en git
