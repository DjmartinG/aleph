# Plantilla de secrets — control de acceso (Fase 1) y Supabase (Fase 2).
# Copia este contenido en Streamlit Cloud -> App -> Settings -> Secrets (NO se sube al repo).
# En local: crea .streamlit/secrets.toml con estos valores (ya esta en .gitignore).

# --- Control de acceso ---
# Si NO defines CLAVE_EQUIPO, la app queda ABIERTA (rol editor) — util en local.
# Si la defines, se exige clave para VER el tablero.
CLAVE_EQUIPO = "pon-aqui-una-clave-fuerte-de-equipo"   # la conoce el equipo (solo lectura)
CLAVE_EDITOR = "pon-aqui-una-clave-fuerte-de-editor"   # solo tu + 1-2 (ingreso de datos)

# --- Supabase (Fase 2 — se completa cuando crees el proyecto) ---
# SUPABASE_URL = "https://xxxxxxxx.supabase.co"
# SUPABASE_KEY = "service-role-key-aqui"   # service role (servidor); NO en el repo
