# Plantilla de secrets — credenciales de Supabase para los scripts de datos locales.
# Copia este archivo a .streamlit/secrets.toml (ya está en .gitignore; NUNCA al repo) y rellena los
# valores. Los scripts (db/etl_import_v1.py, db/refresh_scenarios.py, migrate_db.ps1) PREFIEREN las
# variables de entorno SUPABASE_URL / SUPABASE_KEY; este archivo es solo el respaldo local.
#
# En PRODUCCIÓN los secretos van como App Settings del App Service (API) / Vercel (web), NO en archivo.

SUPABASE_URL = "https://xxxxxxxx.supabase.co"
SUPABASE_KEY = "service-role-key-aqui"   # service role (servidor); NUNCA en el repo
