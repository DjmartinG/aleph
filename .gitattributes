# Normalización de fin de línea. Todo el TEXTO se almacena y se revisa con LF (consistente en
# Windows/Linux/CI), evitando diffs fantasma por CRLF. Excepción: scripts de Windows en CRLF.

* text=auto eol=lf

# Scripts de shell: LF obligatorio (un CRLF rompe el shebang en Linux/CI/Git Bash: "bad interpreter ^M").
*.sh    text eol=lf

# Scripts de Windows: CRLF es lo convencional (PowerShell / cmd).
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binarios: git NO debe aplicarles conversión de fin de línea.
*.png   binary
*.ico   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.xlsx  binary
*.xlsm  binary
*.xls   binary
*.zip   binary
*.pdf   binary
